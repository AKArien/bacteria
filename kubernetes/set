apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: bacteria
spec:
  serviceName: bacteria
  replicas: 3

  selector:
    matchLabels:
      app: bacteria

  template:
    metadata:
      labels:
        app: bacteria

    spec:
      containers:
      - name: bacteria
        image: myregistry/bacteria-service:v1

        ports:
        - containerPort: 50051

        volumeMounts:
        - name: data
          mountPath: /data


  volumeClaimTemplates:
  - metadata:
      name: data

    spec:
      accessModes:
      - ReadWriteOnce

      resources:
        requests:
          storage: 1Gi
